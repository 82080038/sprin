{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start PHP Built-in Server",
      "type": "shell",
      "command": "php",
      "args": [
        "-S",
        "localhost:8000",
        "-t",
        "${workspaceFolder}"
      ],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Run PHPStan",
      "type": "shell",
      "command": "vendor/bin/phpstan",
      "args": [
        "analyse",
        "--memory-limit=2G"
      ],
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Run PHPUnit Tests",
      "type": "shell",
      "command": "vendor/bin/phpunit",
      "args": [
        "--configuration",
        "phpunit.xml"
      ],
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Run Jest Tests",
      "type": "shell",
      "command": "npm",
      "args": [
        "test"
      ],
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Run Playwright Tests",
      "type": "shell",
      "command": "npx",
      "args": [
        "playwright",
        "test"
      ],
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}