{
  "php.executablePath": "/opt/lampp/bin/php",
  "php.validate.executablePath": "/opt/lampp/bin/php",
  "intelephense.environment.phpVersion": "8.2",
  "intelephense.files.maxSize": 15000000,
  "intelephense.completion.maxItems": 200,
  "intelephense.diagnostics.enable": true,
  "intelephense.diagnostics.run": "onSave",
  "intelephense.diagnostics.deprecated": true,
  "intelephense.diagnostics.security": true,
  "intelephense.diagnostics.undefinedTypes": false,
  "intelephense.diagnostics.undefinedVariables": false,
  "intelephense.diagnostics.undefinedSymbols": false,
  "intelephense.diagnostics.unusedSymbols": false,
  "intelephense.diagnostics.duplicateSymbols": false,
  "intelephense.diagnostics.languageConstraints": false,
  "intelephense.format.enable": true,
  "intelephense.format.braces": "k&r",
  "intelephense.format.newLine": "\\n",
  "files.associations": {
    "*.php": "php",
    "*.phtml": "php",
    "*.js": "javascript",
    "*.jsx": "javascriptreact",
    "*.ts": "typescript",
    "*.tsx": "typescriptreact",
    "*.json": "json",
    "*.json5": "json",
    "*.md": "markdown",
    "*.sql": "sql",
    "*.py": "python",
    "*.yml": "yaml",
    "*.yaml": "yaml",
    "*.html": "html",
    "*.htm": "html",
    "*.css": "css",
    "*.scss": "scss",
    "*.sass": "sass",
    "*.less": "less",
    "*.xml": "xml",
    "*.txt": "plaintext",
    "*.log": "log",
    "*.env": "dotenv",
    "*.gitignore": "gitignore",
    "*.htaccess": "apacheconf",
    "*.dockerfile": "dockerfile",
    "Dockerfile": "dockerfile",
    "Makefile": "makefile",
    "*.sh": "shellscript",
    "*.bat": "batchfile"
  },
  "emmet.includeLanguages": {
    "php": "html"
  },
  "php.suggest.basic": false,
  "php.validate.run": "onSave",
  "windsurf.codeium.enableAutoCompletion": true,
  "windsurf.codeium.enableCodeChat": true,
  "windsurf.codeium.enableCodeIndex": true,
  "windsurf.codeium.enableInlineCompletion": true,
  "windsurf.codeium.enableDocumentation": true,
  "windsurf.codeium.enableRefactoring": true,
  "windsurf.codeium.enableTesting": true,
  "windsurf.codeium.enableDebugging": true,
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.formatOnType": true,
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.detectIndentation": false,
  "editor.trimAutoWhitespace": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit",
    "source.removeUnusedImports": "explicit",
    "source.sortImports": "explicit"
  },
  "files.exclude": {
    "**/node_modules": true,
    "**/test-results": true,
    "**/playwright-report": true,
    "**/.git": true,
    "**/logs": true,
    "**/backups": true,
    "**/tests/node_modules": true,
    "**/*.tmp": true,
    "**/*.bak": true,
    "**/*~": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/vendor": true,
    "**/.idea": true,
    "**/.vscode": true,
    "**/cache": true,
    "**/tmp": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/test-results": true,
    "**/playwright-report": true,
    "**/.git": true,
    "**/logs": true,
    "**/backups": true,
    "**/tests/node_modules": true,
    "**/*.tmp": true,
    "**/*.bak": true,
    "**/*~": true,
    "**/vendor": true,
    "**/cache": true,
    "**/tmp": true
  },
  "files.watcherExclude": {
    "**/tests/node_modules/**": true,
    "**/logs/**": true,
    "**/backups/**": true,
    "**/vendor/**": true,
    "**/cache/**": true,
    "**/tmp/**": true,
    "**/*.tmp": true,
    "**/*.bak": true,
    "**/*~": true
  },
  "php.debug.executablePath": "/opt/lampp/bin/php",
  "xdebug.php.maxChildren": 1000,
  "xdebug.php.maxDepth": 10,
  "xdebug.php.maxData": 1024,
  "typescript.preferences.includePackageJsonAutoImports": "on",
  "javascript.preferences.includePackageJsonAutoImports": "on",
  "python.defaultInterpreterPath": "/usr/bin/python3",
  "python.linting.enabled": true,
  "python.linting.pylintEnabled": true,
  "python.linting.flake8Enabled": false,
  "python.formatting.provider": "black",
  "python.analysis.typeCheckingMode": "basic",
  "security.workspace.trust.untrustedFiles": "open",
  "security.workspace.trust.enabled": true,
  "security.workspace.trust.banner": "always",
  "phpstan.enable": true,
  "phpstan.configFile": "./phpstan.neon",
  "phpstan.memoryLimit": "2G",
  "phpstan.level": 6,
  "phpstan.autoDiscover": true,
  "emmet.showAbbreviationSuggestions": true,
  "emmet.showExpandedAbbreviation": true,
  "html.autoClosingTags": true,
  "css.autoClosingTags": true,
  "javascript.autoClosingTags": true,
  "typescript.autoClosingTags": true,
  "editor.quickSuggestions": {
    "strings": true,
    "comments": true,
    "other": true
  },
  "editor.suggestSelection": "first",
  "editor.wordBasedSuggestions": true,
  "editor.snippetSuggestions": "top",
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "workbench.iconTheme": "vscode-icons",
  "workbench.colorTheme": "Default Dark+",
  "workbench.startupEditor": "welcomePageInEmptyWorkbench",
  "git.enableSmartCommit": true,
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.postCommitCommand": "none",
  "git.showInlineOpenFileAction": false,
  "terminal.integrated.shell.linux": "/bin/bash",
  "terminal.integrated.env.linux": {
    "PATH": "/opt/lampp/bin:/usr/local/bin:/usr/bin:/bin"
  },
  "debug.allowBreakpointsEverywhere": true,
  "debug.console.closeOnEnd": true,
  "debug.internalConsoleOptions": "openOnSessionStart",
  "testing.automaticallyOpenPeekView": "failureInVisibleDocument",
  "testing.followRunningExtension": true,
  "testing.openTesting": "openOnTestFailure",
  "scm.alwaysShowActions": true,
  "scm.providers": {
    "git": {
      "autoCommit": false,
      "autoCommitDelay": 1
    }
  },
  "extensions.autoUpdate": true,
  "extensions.autoCheckUpdates": true,
  "extensions.ignoreRecommendations": false,
  "telemetry.telemetryLevel": "off",
  "update.mode": "manual",
  "update.enableWindowsBackgroundUpdates": false
}