{
    "php.executablePath": "/opt/lampp/bin/php",
    "php.validate.executablePath": "/opt/lampp/bin/php",
    "intelephense.environment.phpVersion": "8.2",
    "intelephense.files.maxSize": 5000000,
    "intelephense.completion.maxItems": 100,
    "intelephense.diagnostics.enable": true,
    "intelephense.diagnostics.run": "onSave",
    "intelephense.diagnostics.deprecated": true,
    "intelephense.diagnostics.security": true,
    "intelephense.diagnostics.undefinedTypes": true,
    "intelephense.diagnostics.undefinedVariables": true,
    "intelephense.diagnostics.undefinedSymbols": true,
    "intelephense.diagnostics.unusedSymbols": true,
    "intelephense.diagnostics.duplicateSymbols": true,
    "intelephense.diagnostics.languageConstraints": true,
    "intelephense.format.enable": true,
    "intelephense.format.braces": "k&r",
    "intelephense.format.newLine": "\\n",
    "files.associations": {
        "*.php": "php",
        "*.phtml": "php",
        "*.js": "javascript",
        "*.jsx": "javascriptreact",
        "*.ts": "typescript",
        "*.tsx": "typescriptreact",
        "*.json": "json",
        "*.json5": "json",
        "*.md": "markdown",
        "*.sql": "sql",
        "*.py": "python",
        "*.yml": "yaml",
        "*.yaml": "yaml",
        "*.html": "html",
        "*.htm": "html",
        "*.css": "css",
        "*.scss": "scss",
        "*.sass": "sass",
        "*.less": "less",
        "*.xml": "xml",
        "*.txt": "plaintext",
        "*.log": "log",
        "*.env": "dotenv",
        "*.gitignore": "gitignore",
        "*.htaccess": "apacheconf",
        "*.dockerfile": "dockerfile",
        "Dockerfile": "dockerfile",
        "Makefile": "makefile",
        "*.sh": "shellscript",
        "*.bat": "batchfile"
    },
    "emmet.includeLanguages": {
        "php": "html"
    },
    "php.suggest.basic": false,
    "php.validate.run": "onSave",
    "windsurf.codeium.enableAutoCompletion": true,
    "windsurf.codeium.enableCodeChat": true,
    "windsurf.codeium.enableCodeIndex": true,
    "windsurf.codeium.enableInlineCompletion": true,
    "windsurf.codeium.enableDocumentation": true,
    "windsurf.codeium.enableRefactoring": true,
    "windsurf.codeium.enableTesting": true,
    "windsurf.codeium.enableDebugging": true,
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "editor.formatOnType": true,
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,
    "editor.trimAutoWhitespace": true,
    "editor.codeActionsOnSave": {
        "source.fixAll": "explicit",
        "source.organizeImports": "explicit",
        "source.removeUnusedImports": "explicit",
        "source.sortImports": "explicit",
        "phpstan.fixAll": true
    },
    "editor.stickyScroll.enabled": true,
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": true,
    "editor.inlayHints.enabled": "off",
    "editor.lightbulb.enabled": "off",
    "files.exclude": {
        "**/node_modules": true,
        "**/test-results": true,
        "**/playwright-report": true,
        "**/.git": true,
        "**/logs": true,
        "**/backups": true,
        "**/tests/node_modules": true,
        "**/*.tmp": true,
        "**/*.bak": true,
        "**/*~": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "**/vendor": true,
        "**/.idea": true,
        "**/.vscode": true,
        "**/cache": true,
        "**/tmp": true
    },
    "search.exclude": {
        "**/node_modules": true,
        "**/test-results": true,
        "**/playwright-report": true,
        "**/.git": true,
        "**/logs": true,
        "**/backups": true,
        "**/tests/node_modules": true,
        "**/*.tmp": true,
        "**/*.bak": true,
        "**/*~": true,
        "**/vendor": true,
        "**/cache": true,
        "**/tmp": true
    },
    "files.watcherExclude": {
        "**/tests/node_modules/**": true,
        "**/logs/**": true,
        "**/backups/**": true,
        "**/vendor/**": true,
        "**/cache/**": true,
        "**/tmp/**": true,
        "**/*.tmp": true,
        "**/*.bak": true,
        "**/*~": true
    },
    "php.debug.executablePath": "/opt/lampp/bin/php",
    "xdebug.php.maxChildren": 500,
    "xdebug.php.maxDepth": 5,
    "xdebug.php.maxData": 512,
    "typescript.preferences.includePackageJsonAutoImports": "on",
    "javascript.preferences.includePackageJsonAutoImports": "on",
    "python.defaultInterpreterPath": "/usr/bin/python3",
    "python.linting.enabled": true,
    "python.linting.pylintEnabled": true,
    "python.linting.flake8Enabled": true,
    "python.linting.mypyEnabled": true,
    "python.formatting.provider": "black",
    "python.formatting.blackArgs": [
        "--line-length",
        "120"
    ],
    "python.analysis.typeCheckingMode": "strict",
    "python.analysis.autoImportCompletions": true,
    "python.analysis.diagnosticSeverityOverrides": {
        "reportMissingImports": "error",
        "reportUndefinedVariable": "error"
    },
    "security.workspace.trust.untrustedFiles": "open",
    "security.workspace.trust.enabled": true,
    "security.workspace.trust.banner": "always",
    "phpstan.enable": true,
    "phpstan.configFile": "./phpstan.neon",
    "phpstan.memoryLimit": "2G",
    "phpstan.level": 8,
    "phpstan.autoDiscover": true,
    "phpstan.neonEditor.enable": true,
    "emmet.showAbbreviationSuggestions": true,
    "emmet.showExpandedAbbreviation": true,
    "html.autoClosingTags": true,
    "css.autoClosingTags": true,
    "javascript.autoClosingTags": true,
    "typescript.autoClosingTags": true,
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "workbench.iconTheme": "vscode-icons",
    "workbench.colorTheme": "Default Dark+",
    "workbench.startupEditor": "welcomePageInEmptyWorkbench",
    "terminal.integrated.shell.linux": "/bin/bash",
    "terminal.integrated.env.linux": {
        "PATH": "/opt/lampp/bin:/usr/local/bin:/usr/bin:/bin",
        "PHP_INI_SCAN_DIR": "/opt/lampp/etc"
    },
    "debug.allowBreakpointsEverywhere": true,
    "debug.console.closeOnEnd": true,
    "debug.internalConsoleOptions": "openOnSessionStart",
    "testing.automaticallyOpenPeekView": "failureInVisibleDocument",
    "testing.followRunningExtension": true,
    "testing.openTesting": "openOnTestFailure",
    "playwright.cli": "node test_login_puppeteer.js",
    "playwright.reuseBrowser": true,
    "playwright.showTrace": true,
    "scm.alwaysShowActions": true,
    "scm.providers": {
        "git": {
            "autoCommit": false,
            "autoCommitDelay": 1
        }
    },
    "telemetry.telemetryLevel": "off",
    "update.mode": "manual",
    "update.enableWindowsBackgroundUpdates": false,
    "workbench.editor.enablePreview": false,
    "workbench.list.horizontalScrolling": false,
    "editor.minimap.enabled": false,
    "editor.renderControlCharacters": false,
    "editor.renderWhitespace": "selection",
    "editor.occurrenceHighlight": false,
    "editor.matchBrackets": "always",
    "editor.colorDecorators": false,
    "editor.parameterHints.enabled": false,
    "editor.hover.enabled": true,
    "editor.hover.sticky": false,
    "files.maxMemoryForLargeFilesMB": 2048,
    "typescript.tsserver.maxTsServerMemory": 2048,
    "typescript.tsserver.experimental.enableProjectDiagnostics": false,
    "javascript.suggestionActions.enabled": false,
    "typescript.suggestionActions.enabled": false,
    "typescript.disableAutomaticTypeAcquisition": true,
    "npm.enableRunFromFolder": false,
    "search.smartCase": false,
    "search.useGlobalIgnoreFiles": true,
    "search.useIgnoreFiles": true,
    "search.useParentIgnoreFiles": true,
    "extensions.autoUpdate": false,
    "extensions.autoCheckUpdates": false,
    "ai_assistance": {
        "application_context": {
            "name": "SPRIN - Police Management System",
            "primary_language": "PHP",
            "framework": "Custom MVC-like with Bootstrap",
            "database": "MySQL with PDO",
            "authentication": "Session-based with AuthHelper",
            "api_style": "RESTful with JSON responses"
        },
        "development_focus": [
            "Code quality and standards",
            "Security best practices",
            "Performance optimization",
            "User experience enhancement",
            "Error debugging and resolution"
        ],
        "key_concepts": [
            "SessionManager for session handling",
            "AuthHelper for authentication",
            "PDO for database operations",
            "Bootstrap for responsive design",
            "API endpoints for data operations"
        ],
        "forbidden_patterns": [
            "Hardcoded database credentials",
            "Direct SQL without prepared statements",
            "Missing authentication checks",
            "Unvalidated user input",
            "Error information exposure in production"
        ]
    }
}