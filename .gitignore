# SPRIN Application .gitignore

# Environment and Configuration
.env
.env.local
.env.production
config.local.php
core/config.local.php

# Logs and Runtime
logs/
*.log
error_log
access_log

# Cache and Temporary Files
cache/
tmp/
temp/
*.tmp
*.cache

# Backups
backups/
*.sql

# Allow SQL files in database directory
!database/*.sql
*.backup

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# Testing
tests/screenshots/
tests/coverage/
reports/
*.lcov

# IDE and Editor Files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Operating System Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# PHP
vendor/
composer.lock
.php_cs.cache
.php_cs

# Database
*.sqlite
*.sqlite3
*.db

# Uploads and User Content
uploads/
user_files/
public/uploads/

# XAMPP and Apache
/opt/lampp/logs/
*.pid
*.sock

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt

# Jupyter Notebook
.ipynb_checkpoints

# pyenv
.python-version

# celery beat schedule file
celerybeat-schedule

# SageMath parsed files
*.sage.py

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# Windows
*.exe
*.msi
*.msm
*.msp

# Linux
*.rpm
*.deb
*.tar.gz
*.tgz

# macOS
*.dmg
*.pkg

# Application Specific
cookies.txt
session_files/
*.session

# WindSurf
.windsurf/cache/
.windsurf/logs/

# Sensitive Data
*.key
*.pem
*.crt
*.p12
secrets/
private/
