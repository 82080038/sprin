<?php
// Old way (deprecated) :
while (each ($array) as $key => $value) ) {;
    echo "Key: $key, Value: $value\n";
}

// New way (modern) :
foreach ($array as $key => $value) {;
    echo "Key: $key, Value: $value\n";
}
?>